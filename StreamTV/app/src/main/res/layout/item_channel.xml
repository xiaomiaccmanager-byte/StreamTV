<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="62dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="@drawable/bg_channel_item">

    <!-- Icon -->
    <TextView
        android:id="@+id/tv_channel_emoji"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:textSize="18sp"
        android:background="@drawable/bg_channel_icon"
        android:layout_marginEnd="12dp"/>

    <!-- Meta -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:fontFamily="monospace"/>
        <TextView
            android:id="@+id/tv_now_playing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Live dot -->
    <View
        android:id="@+id/live_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/live_dot"/>

    <!-- Number -->
    <TextView
        android:id="@+id/tv_channel_num"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:textSize="9sp"
        android:textColor="@color/text_muted2"
        android:fontFamily="monospace"
        android:gravity="end"/>
</LinearLayout>