<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- ExoPlayer View -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fit"/>

    <!-- Scanlines overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/scanlines"
        android:alpha="0.08"
        android:clickable="false"/>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent"
        android:visibility="visible"/>

    <!-- Error text -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#888888"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Controls overlay -->
    <LinearLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/gradient_top">
            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="\u2190 Назад"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_dark"
                android:textSize="11sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="14dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_channel_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/accent"
                    android:fontFamily="monospace"/>
                <TextView
                    android:id="@+id/tv_show_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="\u25CF ЭФИР"
                android:textSize="9sp"
                android:textColor="@color/white"
                android:background="@color/accent"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"
                android:layout_marginEnd="8dp"/>
            <Button
                android:id="@+id/btn_pip"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="\u2750"
                android:textColor="@color/white"
                android:background="@drawable/bg_btn_dark"
                android:padding="0dp"/>
        </LinearLayout>

        <!-- Spacer -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Episode info bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp"
            android:background="@drawable/gradient_bottom">
            <TextView
                android:id="@+id/tv_episode_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- TIMELINE -->
        <com.google.android.material.slider.Slider
            android:id="@+id/timeline_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:valueFrom="0"
            android:valueTo="100"
            android:value="0"
            app:thumbColor="@color/accent"
            app:trackColorActive="@color/accent"
            app:trackColorInactive="@color/bg_tertiary"
            app:thumbRadius="6dp"
            app:trackHeight="3dp"
            android:background="@color/bg_primary"/>

        <!-- BOTTOM CONTROLS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@color/bg_primary">

            <Button android:id="@+id/btn_rewind"
                android:layout_width="44dp" android:layout_height="40dp"
                android:text="\u23ea 10"
                android:textSize="11sp" android:textColor="@color/text_muted"
                android:background="@android:color/transparent"/>
            <Button android:id="@+id/btn_play_pause"
                android:layout_width="52dp" android:layout_height="44dp"
                android:text="\u23f8"
                android:textSize="22sp" android:textColor="@color/white"
                android:background="@android:color/transparent"/>
            <Button android:id="@+id/btn_forward"
                android:layout_width="44dp" android:layout_height="40dp"
                android:text="10 \u23e9"
                android:textSize="11sp" android:textColor="@color/text_muted"
                android:background="@android:color/transparent"/>

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="10sp"
                android:textColor="@color/text_muted2"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textSize="10sp"
                android:textColor="@color/text_muted2"/>
            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="10sp"
                android:textColor="@color/text_muted2"
                android:fontFamily="monospace"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <Button android:id="@+id/btn_next"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Следующий \u25ba"
                android:textSize="10sp" android:textColor="@color/text_muted"
                android:background="@drawable/bg_btn_outline"
                android:paddingStart="12dp" android:paddingEnd="12dp"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>