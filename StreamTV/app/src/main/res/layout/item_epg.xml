<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@drawable/bg_epg_item">

    <!-- Time column -->
    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:fontFamily="monospace"/>
        <TextView
            android:id="@+id/tv_end_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textColor="@color/text_muted2"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Thumbnail -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="42dp"
        android:layout_marginEnd="14dp">
        <ImageView
            android:id="@+id/iv_thumb"
            android:layout_width="72dp"
            android:layout_height="42dp"
            android:background="@color/bg_tertiary"
            android:scaleType="centerCrop"/>
        <TextView
            android:id="@+id/tv_thumb_emoji"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="22sp"
            android:visibility="visible"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_show_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"/>
        <TextView
            android:id="@+id/tv_episode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">
            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/text_muted2"/>
            <TextView
                android:id="@+id/tv_time_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:textColor="@color/accent"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>
        </LinearLayout>
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/bg_tertiary"
            android:max="100"
            android:layout_marginTop="5dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- NOW badge -->
    <TextView
        android:id="@+id/badge_now"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="СЕЙЧАС"
        android:textSize="8sp"
        android:textColor="@color/white"
        android:background="@color/accent"
        android:paddingStart="6dp" android:paddingEnd="6dp"
        android:paddingTop="3dp" android:paddingBottom="3dp"
        android:layout_marginStart="8dp"
        android:visibility="gone"/>
</LinearLayout>